<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="10dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvImpactTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Impact"
            android:textColor="@color/text_color"
            android:textSize="22sp"
            android:layout_margin="10dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Filter Dropdown -->
        <TextView
            android:id="@+id/tvFilter"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="10dp"
            android:background="@drawable/search_bg"
            android:drawableEnd="@drawable/ic_arrow_down"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="This Month"
            android:textColor="@color/text_color"
            app:layout_constraintTop_toBottomOf="@id/tvImpactTitle" />

        <!-- Summary Cards Section -->
        <LinearLayout
            android:id="@+id/layoutSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvFilter">

            <!-- Card 1: Food Saved -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFood"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/card_shade"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="7dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:id="@+id/ivFoodIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_bg_light"
                        android:padding="6dp"
                        android:src="@drawable/ic_food_new"
                        app:tint="@color/my_light_primary" />

                    <TextView
                        android:id="@+id/tvFoodLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Food Saved"
                        android:textColor="#666"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvFoodValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="12.4 kg"
                        android:textColor="@color/text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <!-- Card 2: Money Saved -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMoney"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/card_shade"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:id="@+id/ivMoneyIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_bg_light"
                        android:padding="6dp"
                        android:src="@drawable/ic_money"
                        app:tint="@color/my_light_primary" />

                    <TextView
                        android:id="@+id/tvMoneyLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Money Saved"
                        android:textColor="#666"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvMoneyValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="$64.20"
                        android:textColor="@color/text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <!-- Card 3: CO2 Reduced -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCO2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/card_shade"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginStart="7dp"
                android:layout_marginEnd="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:id="@+id/ivCO2Icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_bg_light"
                        android:padding="6dp"
                        android:src="@drawable/ic_eco"
                        app:tint="@color/my_light_primary" />

                    <TextView
                        android:id="@+id/tvCO2Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="CO2 Reduced"
                        android:textColor="#666"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvCO2Value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="28.5 kg"
                        android:textColor="@color/text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:id="@+id/tvProgressTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Your Progress"
            android:textColor="@color/text_color"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutSummary" />

        <!-- Progress Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_shade"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            android:layout_margin="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvProgressTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp">

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="78"
                        android:progressDrawable="@drawable/circular_progress" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="78%"
                        android:textColor="@color/text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Great job!"
                        android:textColor="@color/text_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="You're doing better\nthan last month."
                        android:textColor="#666"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="History"
            android:textColor="@color/text_color"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardProgress" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="See All"
            android:textColor="@color/my_light_primary"
            android:textStyle="bold"
            android:layout_marginEnd="10dp"
            app:layout_constraintBottom_toBottomOf="@id/tvHistoryTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvHistoryTitle" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChartHistory"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHistoryTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>